function getFlattenedDefaultDpaData_() {
  const rows = [];
  getDefaultDpaData_().forEach(function(sub) {
    sub.items.forEach(function(item, idx) {
      rows.push(Object.assign({
        id: 'DPA-' + sub.kode + '-' + String(idx + 1).padStart(2, '0'),
        kode: sub.kode,
        nama: sub.nama,
        indikator: sub.indikator
      }, item));
    });
  });
  return rows;
}

